# OCR Gateway — 本地开发环境（Windows 宿主机原生）
#
# 复制：deploy\local\gateway.env.example -> deploy\local\gateway.env
# 启动：deploy\local\run.ps1
#
# OCR 业务配置（LLM、gitlab.api_token）：~/.opencodereview/config.json（本文件不含）
#
# ── 端口对应（本地默认，勿混用）────────────────────────────────────────
#   :8000  GitLab（本地实例，默认 Docker 或自建）— 下面 OCR_GATEWAY_GITLAB_* 指向此处
#   :8010  OCR Gateway（本机 run.ps1 监听）— OCR_GATEWAY_PORT；健康检查 /health
#
#   GitLab CI Job（Runner 在 Docker 内）访问 Gateway：
#     GitLab Variable / snippet：OCR_GATEWAY_URL=http://host.docker.internal:8010
#     请求头：X-OCR-Gateway-Token = 与本文件 OCR_GATEWAY_SECRET 相同
#
#   本机自测 Gateway：curl http://localhost:8010/health
#   本机自测 GitLab： curl http://localhost:8000/-/health 或浏览器打开 :8000
# ─────────────────────────────────────────────────────────────────────

# 鉴权密钥（必填）。须与 GitLab CI/CD Variables 中 OCR_GATEWAY_SECRET 一致
OCR_GATEWAY_SECRET=local-dev-secret

# GitLab 基址（:8000）— Gateway 用于 git clone / API 发帖
OCR_GATEWAY_GITLAB_URL=http://localhost:8000
OCR_GATEWAY_GITLAB_API_URL=http://localhost:8000
OCR_GATEWAY_GITLAB_PUBLIC_URL=http://localhost:8000

OCR_GATEWAY_MAX_CONCURRENT=2
OCR_REVIEW_CONCURRENCY=4

# OCR_GATEWAY_MR_NOTES=1
# OCR_GATEWAY_WORKSPACE_MAX_PROJECTS=20

# Gateway 监听端口（:8010）。一般无需改；改后须同步 CI 的 OCR_GATEWAY_URL 端口
# OCR_GATEWAY_PORT=8010
