# OCR Severity Dashboard — 本地开发（Windows）
#
# 复制：deploy\local\viewer.env.example -> deploy\local\viewer.env
# 启动：deploy\local\run_viewer.ps1
#
# 与官方 OCR Viewer 配合使用：
#   ocr viewer                    # :5483 官方 session 详情
#   .\deploy\local\run_viewer.ps1 # :5484 severity 仪表盘
#
# ── 端口 ─────────────────────────────────────────────────────────────
#   :5483  官方 ocr viewer（open-code-review 源码或 npm 全局 ocr）
#   :5484  ocr-ci2 Severity Dashboard（本脚本）
# ─────────────────────────────────────────────────────────────────────

# JSONL 根目录（默认 %USERPROFILE%\.opencodereview\sessions）
# OCR_SESSIONS_DIR=

# 官方 viewer 基址（用于「官方详情」链接）
OCR_VIEWER_URL=http://localhost:5483

# Severity Dashboard 监听
SEVERITY_VIEWER_HOST=127.0.0.1
SEVERITY_VIEWER_PORT=5484

# 非 loopback 访问时扩展 Host 白名单（逗号分隔，慎用）
# SEVERITY_VIEWER_ALLOWED_HOSTS=
