# OCR Gateway — 生产原生（Linux 宿主机）
#
# 复制：deploy/prod/native/gateway.env.example -> deploy/prod/native/gateway.env
# 运行：./deploy/prod/native/run.sh 或 systemd（见 ocr-gateway.service.example）
#
# OCR 业务配置：~/.opencodereview/config.json
#
# ── 端口对应 ──────────────────────────────────────────────────────────
#   GitLab     :8000（或实际部署端口）— OCR_GATEWAY_GITLAB_* / API_URL
#   Gateway    :8010（默认）— OCR_GATEWAY_PORT；CI 用 OCR_GATEWAY_URL 指向 Gateway 端口
#   生产 Linux CI 常写：OCR_GATEWAY_URL=http://<宿主机IP>:8010
# ─────────────────────────────────────────────────────────────────────

OCR_GATEWAY_SECRET=change-me-in-production

# GitLab（:8000 或实际地址）— clone / API
OCR_GATEWAY_GITLAB_URL=http://localhost:8000
OCR_GATEWAY_GITLAB_API_URL=http://localhost:8000
OCR_GATEWAY_GITLAB_PUBLIC_URL=https://gitlab.example.com

OCR_GATEWAY_WORK_ROOT=/var/ocr-gateway/work
OCR_GATEWAY_MAX_CONCURRENT=2
OCR_REVIEW_CONCURRENCY=4

# 官方 OCR Viewer 开关（默认 0，Dashboard 不展示官方 viewer 跳转链接）
# OCR_VIEWER_ENABLED=0
# OCR_VIEWER_URL=http://localhost:5483

# 方案 C Vue SPA（默认 1；设 0 回退 HTMX；需已构建 viewer-spa/dist，经典版在 /legacy）
OCR_DASHBOARD_SPA=1

# OCR_GATEWAY_MR_NOTES=0
# OCR_GATEWAY_WORKSPACE_MAX_PROJECTS=20
# OCR_GATEWAY_PORT=8010
