# OCR Gateway — 生产 Docker compose 环境参考
# 实际值多在 docker-compose.yml；可用 compose env_file 覆盖
#
# ── 端口对应（Docker 同网）──────────────────────────────────────────
#   GitLab 容器 :8000 — OCR_GATEWAY_GITLAB_* 用 http://gitlab:8000（服务名 gitlab）
#   Gateway 容器 :8010 — 映射宿主机 8010；CI 用 OCR_GATEWAY_URL=http://ocr-gateway:8010
# ─────────────────────────────────────────────────────────────────────

OCR_GATEWAY_SECRET=change-me-in-production
OCR_GATEWAY_GITLAB_URL=http://gitlab:8000
OCR_GATEWAY_GITLAB_API_URL=http://gitlab:8000
OCR_GATEWAY_GITLAB_PUBLIC_URL=http://localhost:8000
OCR_GATEWAY_WORK_ROOT=/var/ocr-gateway/work
OCR_GATEWAY_MAX_CONCURRENT=2

# 官方 OCR Viewer 开关（默认 0，Dashboard 不展示官方 viewer 跳转链接）
# 如需启用，需额外部署 ocr viewer 并设置 OCR_VIEWER_URL
# OCR_VIEWER_ENABLED=0
# OCR_VIEWER_URL=http://localhost:5483

# 方案 C Vue SPA（默认 1；镜像已含 viewer-spa/dist；设 0 回退 HTMX，经典版在 /legacy）
OCR_DASHBOARD_SPA=1
