# Aulton 生产 Gateway 网络参数（非密钥，可提交 Git）
#
# 用途：
#   - 运维：防火墙放行、compose 端口核对
#   - 开发：GitLab 群组 CI Variables 取值
#   - 勿与 prod.config.json（LLM/PAT）混放
#
# 机器：172.16.5.119
# compose：deploy/prod/docker/docker-compose.standalone.yml（ports: 48010:8010）

# 宿主机内网 IP（Runner / 浏览器访问用）
GATEWAY_HOST=172.16.5.119

# 宿主机映射端口（非容器内 8010）
GATEWAY_PORT=48010

# GitLab 群组 / 实例 CI Variable（code-review Job curl 目标）
OCR_GATEWAY_URL=http://172.16.5.119:48010

# Dashboard（浏览器，与 OCR_GATEWAY_URL 同 host:port）
# http://172.16.5.119:48010/

# GitLab 公网（compose environment 已写，此处备查）
OCR_GATEWAY_GITLAB_URL=https://gitlab.aulton.com
OCR_GATEWAY_GITLAB_API_URL=https://gitlab.aulton.com
OCR_GATEWAY_GITLAB_PUBLIC_URL=https://gitlab.aulton.com
