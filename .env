LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2

# Review behavior
REVIEW_MAX_INPUT_TOKENS=12000
CONTEXT_MAX_CHARS=8000

# GitLab Webhook (optional, for webhook-triggered reviews)
GITLAB_WEBHOOK_SECRET=
