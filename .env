# =============================================
# LLM Provider (only aicr-reviewer container needs these)
# =============================================
LLM_PROVIDER=ctyun_openai
LLM_API_BASE=https://wishub-x6.ctyun.cn/v1
# LLM_API_KEY — set your actual key below (from 天翼云 服务组 AppKey)
LLM_API_KEY=
# LLM_MODEL — set the model ID from 天翼云 console (e.g. DeepSeek-V3.2-Pro model_id)
