# aicr-bot Personal Access Token (used by reviewer service and CI jobs)
# Scopes: at least api (read MR diffs + post discussions/comments)
AICR_BOT_TOKEN=glpat-1MNZdiTCJqmAem0jUt0rrm86MQp1OnoH.01.0w0fhrekj

# GitLab instance base URL (internal for containers)
GITLAB_URL=http://localhost:8000

# Root Personal Access Token (full admin rights)
# Created using the one-time root password for initial setup and automation.
# Recommended scopes: api
# After creation, delete or comment out the original password reference.
