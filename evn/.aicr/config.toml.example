# 复制为 evn/.aicr/config.toml（或通过 AICR_CONFIG_PATH 指定路径）
# 环境变量优先于本文件；密钥仍应放在 evn/.env

[review]
# CI 门禁分数线（可被环境变量 AICR_SCORE_THRESHOLD 覆盖）
score_threshold = 60
# 低分或存在 critical/major 时二次 LLM reflection
self_reflection = true
# 丢弃 diff hunk 外的 issue
filter_issues_to_diff = true

[tools]
# 启用 POST /describe
describe_enabled = true
# 为 true 时 POST /describe 可将生成内容写回 MR 描述
describe_update_mr = false
# 启用 POST /changelog
changelog_enabled = true
# 启用 MR Note 评论对话（Webhook）
ask_enabled = true
# describe 写回 MR 后，在此秒数内跳过 MR update webhook 触发的全量评审
suppress_review_after_describe = true
describe_webhook_suppress_seconds = 120

[ask]
# 在 MR 评论中触发对话（Note webhook）
triggers = ["@aicr", "/ask"]
# 忽略机器人自身用户名，避免回复循环
bot_username = "aicr-bot"

[llm.describe]
# model = ""          # 空则使用 LLM_MODEL
temperature = 0.3

[llm.changelog]
temperature = 0.2

[llm.ask]
temperature = 0.4
