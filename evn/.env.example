# 复制为 evn/.env 并填写真实值（切勿提交 .env 到 Git）
# 完整说明见 docs/SECRETS.md

# --- GitLab ---
AICR_BOT_TOKEN=glpat-...
GITLAB_URL=http://localhost:8000
ROOT_PAT=glpat-...

# Review API auth (CI sends X-AICR-Secret)
REVIEW_API_SECRET=
# Local only: allow /review without REVIEW_API_SECRET (never use in production)
REVIEW_API_ALLOW_INSECURE=0

# GitLab API client
GITLAB_TIMEOUT_SECONDS=30
GITLAB_API_RETRIES=3
# Max concurrent /review + webhook reviews
REVIEW_MAX_CONCURRENT=2

LLM_PROVIDER=ctyun_openai
LLM_API_BASE=https://wishub-x6.ctyun.cn/v1
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2

AICR_SCORE_THRESHOLD=60
REVIEW_MAX_INPUT_TOKENS=12000
CONTEXT_MAX_CHARS=8000
REVIEW_DRY_RUN=0

# 阶段 A：tiktoken 分块、diff 压缩、增量评审
REVIEW_USE_TIKTOKEN=1
TIKTOKEN_ENCODING=cl100k_base
AICR_INCREMENTAL_REVIEW=1
AICR_FORCE_FULL_REVIEW=0
# AICR_STATE_DIR=<repo>/evn/.aicr-state

# P2：增量默认不拉全文；并行 chunk；head 未变时跳过 LLM
AICR_FETCH_FULL_FILE=1
AICR_FETCH_FULL_FILE_ON_INCREMENTAL=0
REVIEW_CHUNK_MAX_WORKERS=2

GITLAB_WEBHOOK_SECRET=
# Set to 1 only for local webhook testing without secret
GITLAB_WEBHOOK_ALLOW_INSECURE=0
