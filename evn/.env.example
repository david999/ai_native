# 复制为 evn/.env 并填写真实值（切勿提交 .env 到 Git）
# 完整说明见 docs/环境变量与密钥.md
# 加载优先级：操作系统环境变量（User/Machine）> 本文件非空值

# --- GitLab ---
# Bot/PAT：读 MR diff、发评审评论（L3 必填）
AICR_BOT_TOKEN=glpat-...
# GitLab 根 URL；本地 CE 默认 http://localhost:8000，Compose 同网用 http://gitlab:8000
GITLAB_URL=http://localhost:8000
# 管理员 PAT：GitLab 初始化/管理用，与 Bot Token 职责分离
ROOT_PAT=glpat-...
# L3 验收：GitLab 不可达时由脚本自动 ensure_rancher + compose（一般不必手配）
# GITLAB_START_COMMAND=...   # 可选：覆盖默认 Rancher 启动链路

# --- Rancher Desktop（L3 自动启动，可选覆盖路径）---
# RANCHER_RDCTL=C:\Program Files\Rancher Desktop\resources\resources\win32\bin\rdctl.exe  # rdctl 可执行文件
# RANCHER_DOCKER_BIN=%USERPROFILE%\.rd\bin  # Rancher 自带的 docker CLI 目录
# GitLab CE 镜像；Docker Hub 不可达时 start.ps1 会用 GITLAB_IMAGE_MIRROR 拉取并 tag
# GITLAB_IMAGE_MIRROR=docker.m.daocloud.io/gitlab/gitlab-ce:latest

# GitLab Runner 容器镜像（L3b）；Docker Hub 不可达时用 start_runner.ps1，勿裸跑 compose pull
# GITLAB_RUNNER_IMAGE_MIRROR=docker.m.daocloud.io/gitlab/gitlab-runner:latest

# --- Review API 鉴权（CI / 脚本调用 POST /review）---
# 共享密钥；CI 在 Header 传 X-AICR-Secret（GitLab CI 变量名 AICR_REVIEW_SECRET）
REVIEW_API_SECRET=
# 仅本地：1=未配置 REVIEW_API_SECRET 时仍允许 /review（生产务必 0）
REVIEW_API_ALLOW_INSECURE=0

# --- GitLab API 客户端 ---
# 单次 GitLab HTTP 请求超时（秒）
GITLAB_TIMEOUT_SECONDS=30
# GitLab API 失败重试次数
GITLAB_API_RETRIES=3
# 同时进行的最大 /review + webhook 评审数
REVIEW_MAX_CONCURRENT=2

# --- LLM ---
# 预设：ctyun_openai、deepseek、zhipu、openai
LLM_PROVIDER=ctyun_openai
# OpenAI 兼容 API 根地址（可覆盖 provider 预设）
LLM_API_BASE=https://wishub-x6.ctyun.cn/v1
# LLM API Key（L3 真实评审必填；OS 环境变量优先于本文件）
LLM_API_KEY=
# 模型 ID，如 deepseek-chat、tool-model
LLM_MODEL=
# 单次 LLM HTTP 请求超时（秒）
LLM_TIMEOUT_SECONDS=120
# 单次 completion max_tokens 上限
LLM_MAX_TOKENS=4096
# 采样温度（0~1，评审建议偏低）
LLM_TEMPERATURE=0.2


# --- 评审输出与门禁 ---
# CI 门禁分数线：review_completed=true 且 score 低于此值时 job 失败
AICR_SCORE_THRESHOLD=60
# 每个 diff 分块送入模型的估算 token 上限
REVIEW_MAX_INPUT_TOKENS=12000
# 仓库 .llm/CONTEXT.md 注入时的最大字符数
CONTEXT_MAX_CHARS=8000
# 1=只返回 API 结果、不向 GitLab 发评论；L3-full 须 0
REVIEW_DRY_RUN=0

# --- 阶段 A：分块、压缩、增量 ---
# 1=用 tiktoken 估算 token；0=字符数÷4 粗估
REVIEW_USE_TIKTOKEN=1
# tiktoken 编码名
TIKTOKEN_ENCODING=cl100k_base
# 1=启用增量评审（对比上次已评审 SHA）
AICR_INCREMENTAL_REVIEW=1
# 1=忽略增量状态，强制全量 MR diff
AICR_FORCE_FULL_REVIEW=0
# 增量 last_reviewed_sha 持久化目录（勿提交 Git）
# AICR_STATE_DIR=<repo>/evn/.aicr-state

# --- 阶段 A/B：全文拉取与并行 ---
# 1=对变更文件拉取源分支全文辅助评审
AICR_FETCH_FULL_FILE=1
# 1=增量 compare 时也拉全文（更慢、更准）
AICR_FETCH_FULL_FILE_ON_INCREMENTAL=0
# 多块 MR 并行 LLM 调用上限（1=串行）
REVIEW_CHUNK_MAX_WORKERS=2

# --- 提示词变体 ---
# 强制 prompts/variants/*.j2 或 system_*.j2；空=按 MR 语言自动选择
# AICR_SYSTEM_TEMPLATE=system_spring_v2_strict

# --- 阶段 B：过滤与 self-reflection ---
# 1=丢弃 diff hunk 外的 issue
AICR_FILTER_ISSUES_TO_DIFF=1
# 1=低分或存在 critical/major 时二次 LLM reflection
AICR_SELF_REFLECTION=1
# 低于该分触发 reflection；默认与 AICR_SCORE_THRESHOLD 相同
AICR_REFLECTION_SCORE_THRESHOLD=60

# --- Webhook ---
# GitLab Webhook 请求头 X-Gitlab-Token 校验值；生产务必设置
GITLAB_WEBHOOK_SECRET=
# 仅本地：1=未配置 GITLAB_WEBHOOK_SECRET 时仍接受 Webhook
GITLAB_WEBHOOK_ALLOW_INSECURE=0

# --- 阶段 C：describe / CHANGELOG / 评论对话 ---
# 部署 TOML 路径；默认自动探测 evn/.aicr/config.toml
# AICR_CONFIG_PATH=<repo>/evn/.aicr/config.toml
# 1=启用 POST /describe 生成 MR 描述
AICR_DESCRIBE_ENABLED=1
# 1=describe 结果写回 MR 标题/描述
AICR_DESCRIBE_UPDATE_MR=0
# 1=启用 POST /changelog
AICR_CHANGELOG_ENABLED=1
# 1=启用 MR Note 评论对话（Webhook）
AICR_ASK_ENABLED=1
# Note 触发词，逗号分隔
AICR_ASK_TRIGGERS=@aicr,/ask
# 识别 Bot 自身评论，避免回复循环
AICR_BOT_USERNAME=aicr-bot
# 1=Webhook 处理 Note create 事件
AICR_WEBHOOK_NOTE_ENABLED=1
# 1=describe 写回 MR 后短时抑制重复 review webhook
AICR_SUPPRESS_REVIEW_AFTER_DESCRIBE=1
# 上述抑制窗口（秒）
AICR_DESCRIBE_WEBHOOK_SUPPRESS_SECONDS=120
# 可选：按工具覆盖 LLM（否则用 LLM_MODEL / config.toml [llm.*]）
# LLM_MODEL_DESCRIBE=
# LLM_TEMPERATURE_CHANGELOG=0.2
